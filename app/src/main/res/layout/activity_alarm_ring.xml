<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:gravity="center"
    android:padding="32dp">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_alarm"
        app:tint="@color/primary"
        android:layout_marginBottom="16dp"
        tools:ignore="ContentDescription"/>

    <TextView
        android:id="@+id/tv_ring_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="72sp"
        android:textStyle="bold"
        tools:text="07:30"/>

    <TextView
        android:id="@+id/tv_ring_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="18sp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="32dp"
        tools:text="İşe gidiş"/>

    <TextView
        android:id="@+id/tv_ring_instruction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/scan_to_dismiss"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textAlignment="center"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_ring_qr_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/accent"
        android:textSize="14sp"
        android:textAlignment="center"
        android:gravity="center"
        android:layout_marginBottom="40dp"
        tools:text="Gerekli: Banyo Şişesi"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_scan_qr"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="@string/scan_button"
        android:textSize="16sp"
        android:textStyle="bold"
        app:icon="@drawable/ic_qr_code"
        app:iconTint="@color/white"
        android:textColor="@color/white"
        app:backgroundTint="@color/accent"
        app:cornerRadius="28dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_dismiss_no_qr"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="@string/dismiss_no_qr"
        android:visibility="gone"
        app:backgroundTint="@color/surface_light"
        app:cornerRadius="28dp"/>

</LinearLayout>
